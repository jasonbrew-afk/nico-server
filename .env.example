# ============================================================================
# Nico — single environment file (canonical source of truth for all secrets/config)
#
#   cp .env.example .env   then fill in the blanks.
#
# Loaded automatically by every component (server, bot, core) for LOCAL dev via a
# tiny walk-up loader in each entrypoint. Values here NEVER override variables
# already set in the real environment.
#
# On Railway: this file is gitignored and NOT deployed — set these in each
# service's Variables tab (or Railway shared variables). This file is your
# checklist of what each service needs.
# ============================================================================

# ---- Broker: Alpaca (default execution backend) -------------------- [server, monitor, core]
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# ---- Execution backend selector ----------------------------------------------- [core]
# alpaca (default) | robinhood_mcp
NICO_EXECUTION_BACKEND=alpaca

# ---- Robinhood MCP backend (only when NICO_EXECUTION_BACKEND=robinhood_mcp) ---- [core, bot]
ROBINHOOD_MCP_ENDPOINT=https://agent.robinhood.com/mcp/trading
# Token file written by the one-time desktop OAuth dance:
#   cd nico-core && python -m platforms.robinhood.mcp_adapter authorize
ROBINHOOD_MCP_TOKENS_FILE=~/.config/nico/robinhood-mcp-tokens.json
# Real-money guard: 1 = every order needs Imago approval (default). 0 = place directly.
ROBINHOOD_REQUIRE_APPROVAL=1

# ---- Imago approval flow ------------------------------------------------- [core, bot]
# run_live -> Imago: sends the order + rationale for your approval
IMAGO_APPROVAL_URL=
IMAGO_API_TOKEN=
# Imago -> nico-bot POST /execute: releases the approved order. Setting this also
# ENABLES the bot's /execute endpoint (unset = endpoint disabled).
IMAGO_EXECUTE_TOKEN=

# ---- Discord bot (nico-bot) --------------------------------------------------- [bot]
BOT_TOKEN=
CHANNEL_ID=
NICO_DAILY_SUMMARY_TIME=16:15          # HH:MM US/Eastern

# ---- Webhook relay server (root main.py / nico-server) ------------------------ [server]
NICO_CORE_URL=http://localhost:8001
ALLOWED_IPS=                            # optional CSV IP allowlist; empty = allow all
# PORT is injected by Railway (default 8000 server / 8080 bot executor); set only for local:
# PORT=8000

# ---- Red-day monitor (nico-core/monitor.py) ----------------------------------- [monitor]
NICO_SYMBOL=SPY
NICO_SERVER_URL=https://nico-server-production.up.railway.app/webhook/alpaca
